# Where the FastAPI backend is reachable from your iPhone.
#
# Local-WiFi development: use your PC's LAN IP, NOT localhost. The phone
# can't reach localhost on the PC. Find yours with `ipconfig` in PowerShell.
#   EXPO_PUBLIC_API_URL=http://192.168.1.42:8000
#
# Tailscale (works from cellular too): use the PC's tailnet hostname or
# Tailscale IP. The PC must be running uvicorn on 0.0.0.0:8000 (it
# already does — that's the --host 0.0.0.0 flag in start-finance-app.bat).
#   EXPO_PUBLIC_API_URL=http://your-pc.tailXXXXX.ts.net:8000
#
# IMPORTANT: must start with EXPO_PUBLIC_ for the value to be embedded
# in the JS bundle that ships to your iPhone.

EXPO_PUBLIC_API_URL=http://CHANGEME:8000
