# Copy to .env and fill in.
# Everything here is optional for Phase 1 — you can run the foundation on manual CSV imports only.

# Database
DATABASE_URL=sqlite:///./finance.db

# API
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173

# Plaid (Phase 2)
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# Background refresh scheduler (Phase 2). Set to false to disable the daemon.
PLAID_REFRESH_ENABLED=true
PLAID_REFRESH_INTERVAL_HOURS=12

# Gmail parsing (Phase 2) — CLI-first OAuth (InstalledAppFlow).
# Download a "Desktop app" OAuth client JSON from Google Cloud Console and save
# it at GMAIL_CREDENTIALS_PATH. GMAIL_TOKEN_PATH is written automatically after
# the first authorize call and silently refreshed on every sync.
GMAIL_CREDENTIALS_PATH=./gmail_credentials.json
GMAIL_TOKEN_PATH=./gmail_token.json
# Comma-separated scopes. Read-only is all we ever need — never request
# send/compose/modify. Changing this will force re-authorization.
GMAIL_SCOPES=https://www.googleapis.com/auth/gmail.readonly
# How far back to look on the first sync (days). Subsequent syncs default to 14d.
GMAIL_INITIAL_LOOKBACK_DAYS=180

# Ollama (optional, for fuzzy categorization)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
